{
  "version": 2,
  "rewrites": [
    { "source": "/api/auth/login", "destination": "/backend/api/auth/login.js" },
    { "source": "/api/auth/register", "destination": "/backend/api/auth/register.js" },
    { "source": "/api/quotes", "destination": "/backend/api/quotes/index.js" },
    { "source": "/api/admin/users", "destination": "/backend/api/admin/users.js" },
    { "source": "/api/admin/quotes", "destination": "/backend/api/admin/quotes.js" },
    { "source": "/(.*)", "destination": "/frontend/dist/index.html" }
  ]
}